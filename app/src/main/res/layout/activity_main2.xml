<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5"
    tools:context=".Main2Activity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- LR SEARCH CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/editTextLR"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Enter DRS No"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="@drawable/edit_bg"/>

            <Button
                android:id="@+id/btnGetLR"
                android:layout_width="110dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/buttonlr"
                android:text="GET LR"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>

        </LinearLayout>

        <!-- DELIVERY DATE CARD -->
        <LinearLayout
            android:id="@+id/llDeliveryDateRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvDeliveryDateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="डिलिव्हरी तारीख"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/edtDeliveryDate"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="Select Delivery Date"
                    android:padding="12dp"
                    android:background="@drawable/edit_bg"/>

                <ImageView
                    android:id="@+id/imgCal"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    android:layout_marginStart="8dp"
                    android:padding="6dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- DOCUMENT TYPE -->
        <Spinner
            android:id="@+id/spinner1"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edit_bg"/>

        <!-- PHOTO BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Take Photo"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/buttonshape"/>

            <Button
                android:id="@+id/btnUploadFile"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Choose File"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/buttonshape"/>

        </LinearLayout>

        <!-- IMAGE PREVIEW CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imageView1"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/txtRemarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Remarks:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:padding="8dp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- UPLOAD BUTTON -->
        <Button
            android:id="@+id/btn2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="UPLOAD"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:background="@drawable/buttonshape"
            android:layout_marginBottom="12dp"/>

        <!-- AUTO UPLOAD -->
        <Button
            android:id="@+id/btnaUpload"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="AUTO UPLOAD"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:background="@drawable/buttonlr"/>

    </LinearLayout>

</ScrollView>